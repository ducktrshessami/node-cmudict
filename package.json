{
  "name": "node-cmudict",
  "version": "2.1.2",
  "description": "cmusphinx/cmudict wrapper",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": "git@github.com:ducktrshessami/node-cmudict.git",
  "author": "ducktrshessami",
  "license": "MIT",
  "scripts": {
    "postinstall": "node dist/install.mjs",
    "types": "tsc --noEmit",
    "prebuild:main": "yarn types",
    "build:main": "tsdown src/index.ts",
    "prebuild:install": "yarn types",
    "build:install": "tsdown src/install.mts",
    "prebuild": "rm -rf dist/",
    "build": "yarn build:main && yarn build:install",
    "pretest": "yarn build && yarn --immutable",
    "test": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "exports": {
    "types": "./dist/index.d.cts",
    "require": "./dist/index.cjs",
    "import": "./dist/index.mjs"
  },
  "dependencies": {
    "tar-fs": "^3.1.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/tar-fs": "^2.0.4",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
